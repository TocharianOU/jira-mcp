# Jira MCP Server – Environment Variables
# Copy to .env for local development

# ── Connection ────────────────────────────────────────────────────────────────
# Jira Cloud: https://yourorg.atlassian.net
# Jira Server/DC: https://jira.yourcompany.com
JIRA_HOST=https://yourorg.atlassian.net

# ── Authentication ────────────────────────────────────────────────────────────
# Jira Cloud: Atlassian account email + API token
#   API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=your.email@company.com
JIRA_TOKEN=your_api_token_here

# Jira Server / Data Center: Personal Access Token (leave JIRA_EMAIL empty)
# JIRA_TOKEN=your_personal_access_token_here

# ── API Version ───────────────────────────────────────────────────────────────
# 3 = Jira Cloud (default, returns ADF description format)
# 2 = Jira Server / Data Center (returns plain text descriptions)
JIRA_API_VERSION=3

# ── TLS ───────────────────────────────────────────────────────────────────────
# true = verify SSL certificate (default)
# false = skip SSL verification (self-signed certs)
JIRA_VERIFY_SSL=true

# ── Timeouts & Limits ─────────────────────────────────────────────────────────
JIRA_TIMEOUT=30000
MAX_TOKEN_CALL=20000

# ── Transport ─────────────────────────────────────────────────────────────────
# stdio (default) | http
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=3009
